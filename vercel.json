{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node",
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

