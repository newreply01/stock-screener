{
  "name": "stock-screener",
  "version": "1.0.0",
  "description": "台股篩選器 - 類似 WantGoo Screener",
  "private": true,
  "scripts": {
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "fetch-data": "node server/twse_fetcher.js",
    "init-db": "node server/db.js --init",
    "build": "npm install --prefix client && npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/server/tests/**/*.test.js"
    ],
    "setupFiles": [],
    "testTimeout": 10000
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.19.0",
    "pm2": "^6.0.14",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
